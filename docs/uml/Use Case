@startuml
left to right direction
skinparam packageStyle rectangle
actor "Разработчик" as Developer
actor "GitHub API" as GitHub
rectangle "ИАС управления состоянием разработчика" {
 usecase "Ввод эмоционального\nсостояния" as UC1
 usecase "Сбор данных\nGitHub" as UC2
 usecase "Оценка состояния\nразработчика" as UC3
 usecase "Расчёт риска\nвыгорания" as UC4
 usecase "Расчёт продуктивности\nY(t)" as UC5
 usecase "Работа\nПИД-регулятора" as UC6
 usecase "Формирование\nуправляющего воздействия" as UC7
 usecase "Просмотр графиков\nи аналитики" as UC8
 usecase "Экспорт истории\nв CSV" as UC9
}
Developer --> UC1
Developer --> UC8
Developer --> UC9
Developer --> UC7
GitHub --> UC2
UC2 --> UC3
UC3 --> UC4
UC3 --> UC5
UC5 --> UC6
UC6 --> UC7
@enduml
